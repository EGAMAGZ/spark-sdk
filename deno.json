{
  "tasks": {
    "test": "vitest"
  },
  "nodeModulesDir": "auto",
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/expect": "jsr:@std/expect@^1.0.18",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "vite": "npm:vite",
    "vitest": "npm:vitest"
  },
  "dependencies": {
    "npm:vite": "^8.0.8",
    "npm:vitest": "^4.1.4"
  },
  "workspace": [
    "packages/client",
    "packages/init",
    "packages/plugin"
  ],
  "fmt": {
    "singleQuote": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended", "jsr", "workspace"]
    }
  },
  "publish": {
    "exclude": [
      "tests/",
      ".github/"
    ]
  }
}
